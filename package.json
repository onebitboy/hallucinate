{
  "name": "club",
  "version": "0.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "concurrently -n web,app -c cyan,yellow \"bun run dev:web\" \"bun run dev:app\"",
    "dev:web": "vite",
    "dev:app": "bun --watch server.ts",
    "build": "bunx tsc && vite build",
    "start": "bun server.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "assimpjs": "^0.0.10"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "concurrently": "^9.2.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  }
}
